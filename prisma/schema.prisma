generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Shop {
  id         String      @id @default(uuid())
  userId     String
  name       String
  billboards Billboard[] @relation("ShopToBillboard")
  categories Category[]  @relation("ShopToCategory")
  sizes      Size[]      @relation("ShopToSize")
  colors      Color[]      @relation("ShopToColor")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Billboard {
  id         String     @id @default(uuid())
  shopId     String
  shop       Shop       @relation("ShopToBillboard", fields: [shopId], references: [id])
  label      String
  imageUrl   String
  categories Category[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId])
}

model Category {
  id          String    @id @default(uuid())
  shopId      String
  shop        Shop      @relation("ShopToCategory", fields: [shopId], references: [id])
  billboardId String
  billboard   Billboard @relation(fields: [billboardId], references: [id])
  name        String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([shopId])
  @@index([billboardId])
}

model Size {
  id        String   @id @default(uuid())
  shopId    String
  shop      Shop     @relation("ShopToSize", fields: [shopId], references: [id])
  name      String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId])
}
model Color {
  id        String   @id @default(uuid())
  shopId    String
  shop      Shop     @relation("ShopToColor", fields: [shopId], references: [id])
  name      String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId])
}
